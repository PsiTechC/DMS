# Replace every CHANGE_ME value before starting the API. Production startup
# validation deliberately rejects localhost, insecure database settings, demo
# accounts, and weak bootstrap credentials.
PORT=8090
APP_ENV=production
PUBLIC_BASE_URL=https://dms.example.com
CORS_ORIGINS=https://dms.example.com
# Example for nginx on the same host. Adjust to your proxy network/CIDR.
TRUSTED_PROXIES=127.0.0.1/32

DB_HOST=CHANGE_ME
DB_PORT=5432
DB_USER=dms_app
DB_PASSWORD=CHANGE_ME
DB_NAME=dms
DB_SSLMODE=verify-full

JWT_SECRET=CHANGE_ME_WITH_AT_LEAST_32_RANDOM_CHARACTERS
JWT_EXPIRY_HOURS=12

EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_FROM_NAME=DMS Notifications
ADMIN_EMAIL=

WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_ADMIN_NUMBER=

# Mount this path on persistent storage in containers/cloud hosting.
UPLOAD_DIR=/var/lib/dms/uploads
MAX_UPLOAD_MB=100

# Keep both false for an existing production database. For first-time
# bootstrap only, enable the admin seed temporarily and use a unique 12+
# character password, then disable it again after the first successful start.
SEED_ADMIN_ENABLED=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=CHANGE_ME_WITH_A_UNIQUE_PASSWORD
SEED_DEMO_ACCOUNTS=false
