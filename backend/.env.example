# ─── Server ───────────────────────────────────────────────────────────────
PORT=8090
APP_ENV=development
PUBLIC_BASE_URL=http://localhost:5180
CORS_ORIGINS=http://localhost:5180
# Comma-separated proxy IPs/CIDRs. Leave empty when accessing Go directly.
TRUSTED_PROXIES=

# ─── Database (PostgreSQL) ────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=dms
DB_SSLMODE=disable

# ─── JWT ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret-string
JWT_EXPIRY_HOURS=12

# ─── SMTP / Email ─────────────────────────────────────────────────────────
# Every query raised by a user is emailed to ADMIN_EMAIL.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@yourdomain.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=you@yourdomain.com
SMTP_FROM_NAME=DMS Notifications
ADMIN_EMAIL=admin@yourdomain.com
EMAIL_ENABLED=true

# ─── WhatsApp (phase 2 — leave disabled for now) ──────────────────────────
WHATSAPP_ENABLED=false
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_ADMIN_NUMBER=

# ─── Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=100

# ─── Seed admin (created on first run) ────────────────────────────────────
SEED_ADMIN_EMAIL=admin@dms.local
SEED_ADMIN_PASSWORD=Admin@123
SEED_ADMIN_ENABLED=true
SEED_DEMO_ACCOUNTS=true
