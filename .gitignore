# Secrets — never commit real SMTP or DB credentials. Keep only sanitized
# templates under version control.
**/.env
**/.env.*
!**/.env.example
!**/.env.production.example

# Uploaded media
backend/uploads/images/*
backend/uploads/videos/*
backend/uploads/manuals/*
backend/uploads/attachments/*
!backend/uploads/**/.gitkeep

# Go
backend/server
backend/server.exe
backend/*.exe
backend/*.exe~
backend/tmp/
.tmp-go-cache/

# Local dev run logs
*-run.stdout.log
*-run.stderr.log

# Node
node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-error.log*

# Editors / OS
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
desktop.ini
