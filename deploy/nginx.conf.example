# Replace dms.example.com and certificate paths. Copy frontend/dist/* into
# /var/www/dms/. The Go API listens privately on 127.0.0.1:8090.
server {
    listen 80;
    server_name dms.example.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name dms.example.com;

    ssl_certificate     /etc/letsencrypt/live/dms.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/dms.example.com/privkey.pem;

    root /var/www/dms;
    index index.html;

    location /api/ {
        proxy_pass http://127.0.0.1:8090;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        client_max_body_size 101m;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    location /uploads/ {
        proxy_pass http://127.0.0.1:8090;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # BrowserRouter deep links such as /dashboard and /device/DMS000001 must
    # return the SPA entry point instead of a web-server 404.
    location / {
        try_files $uri $uri/ /index.html;
    }

    add_header X-Content-Type-Options nosniff always;
    add_header X-Frame-Options DENY always;
    add_header Referrer-Policy strict-origin-when-cross-origin always;
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
}
